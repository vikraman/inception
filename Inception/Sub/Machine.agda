{- _РіЋ_ : Ctx Рєњ Ctx Рєњ Ctx
╬Њ РіЋ ╬х = ╬Њ
╬Њ РіЋ (╬ћ РѕЎ x) = (╬Њ РіЋ ╬ћ) РѕЎ x

РіЋ-assoc : (╬Њ РіЋ ╬е) РіЋ ╬ћ РЅА ╬Њ РіЋ (╬е РіЋ ╬ћ)
РіЋ-assoc {╬Њ} {╬е} {╬х} = refl
РіЋ-assoc {╬Њ} {╬е} {╬ћ РѕЎ x} rewrite РіЋ-assoc {╬Њ} {╬е} {╬ћ} = refl

РіЋ-left-id : (╬Њ : Ctx) Рєњ ╬х РіЋ ╬Њ РЅА ╬Њ
РіЋ-left-id ╬х = refl
РіЋ-left-id (╬Њ РѕЎ x) rewrite РіЋ-left-id ╬Њ = refl

ext-РіЄ-R : (╬Њ РіЋ ╬ћ) РіЄ ╬ћ
ext-РіЄ-R {╬х} {╬х} = wk-╬х
ext-РіЄ-R {╬Њ РѕЎ x} {╬х} = wk-wk (ext-РіЄ-R {╬Њ} {╬х})
ext-РіЄ-R {╬х} {╬ћ РѕЎ x} rewrite РіЋ-left-id (╬ћ РѕЎ x) = wk-id
ext-РіЄ-R {╬Њ РѕЎ xРѓЂ} {╬ћ РѕЎ x} = wk-cong (ext-РіЄ-R {╬Њ РѕЎ xРѓЂ} {╬ћ})

ext-РіЄ-L : (╬Њ РіЋ ╬ћ) РіЄ ╬Њ
ext-РіЄ-L {╬Њ} {╬х} = wk-id
ext-РіЄ-L {╬х} {╬ћ РѕЎ x} = wk-wk ext-РіЄ-L
ext-РіЄ-L {╬Њ РѕЎ xРѓЂ} {╬ћ РѕЎ x} = wk-wk ext-РіЄ-L

i-assoc : (i : ((╬Њ РіЋ ╬е) РіЋ ╬ћ) РѕІ A) Рєњ (╬Њ РіЋ (╬е РіЋ ╬ћ)) РѕІ A
i-assoc {╬Њ} {╬е} {╬ћ} i rewrite РіЋ-assoc {╬Њ} {╬е} {╬ћ} = i

v-assoc : Val ((╬Њ РіЋ ╬е) РіЋ ╬ћ) A Рєњ Val (╬Њ РіЋ (╬е РіЋ ╬ћ)) A
v-assoc {╬Њ} {╬е} {╬ћ} v rewrite РіЋ-assoc {╬Њ} {╬е} {╬ћ} = v

ec : (w : Wk (╬Њ РіЋ ╬ћ) ╬Њ) Рєњ (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬┤ : РЪд ╬ћ РЪД╦Б) Рєњ РЪд ╬Њ РіЋ ╬ћ РЪД╦Б
ec {╬Њ} {╬х} w ╬│ ╬┤ = ╬│
ec {╬Њ} {╬ћ РѕЎ X} w ╬│ (╬┤ , x) = (ec ext-РіЄ-L ╬│ ╬┤ , x)
-}

