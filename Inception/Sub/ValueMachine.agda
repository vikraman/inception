module Inception.Sub.ValueMachine (R : Set) where

open import Function.Base using (id)
open import Data.Product using (projРѓЂ; projРѓѓ; _,_; ╬Б; РѕЃ; ╬Б-syntax; РѕЃ-syntax)

import Relation.Binary.PropositionalEquality as Eq
open Eq using (_РЅА_; refl; trans; cong; sym)
open Eq.РЅА-Reasoning

open import Inception.Sub.Syntax
open import Inception.Sub.CPS R

open import Data.Product as P

variable
  A' B' C' D' X Y Z X' Y' Z' XРѓЂ YРѓЂ ZРѓЂ XРѓѓ YРѓѓ ZРѓѓ XРЌЙ YРЌЙ ZРЌЙ XРєЊ YРєЊ ZРєЊ TРЌЙ : Ty
  ╬Њ' ╬Њ'' ╬Њ''' ╬ћ' ╬ЊРѓЂ ╬ЊРѓѓ ╬ЊРЌЙ ╬ЊРєЊ : Ctx

infix 40 _РќБ
infixr 35 _~>рхЏрхЏРЪе_РЪЕ_
infix 30 _№╣љ_Рќа
infixr 25 _№╣љ_РѕиpmРЪе_РЪЕ_
infixr 25 _№╣љ_РѕиlРЪе_РЪЕ_
infixr 25 _№╣љ_РѕиrРЪе_РЪЕ_
infix 20 Рѕў_
infix 15 _~>рхЏрхЏ_
infix 15 _~>рхЏрхЏ*_

data valStack : (TРЌЙ : Ty) Рєњ (╬Њ РібрхЏ A) Рєњ РЪд ╬Њ РЪД╦Б Рєњ Set where

    _№╣љ_Рќа : (M : ╬Њ РібрхЏ TРЌЙ) Рєњ (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ valStack TРЌЙ M ╬│

    _№╣љ_РѕиpmРЪе_РЪЕ_ : (M : ╬Њ РібрхЏ A `├Ќ B) Рєњ (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ {M' : ╬Њ' РібрхЏ A `├Ќ B} Рєњ {╬│' : РЪд ╬Њ' РЪД╦Б} Рєњ {N : (╬Њ' РѕЎ A РѕЎ B) РібрхЏ C} Рєњ (MРЅАM' : РЪд M РЪДрхЏ ╬│ РЅА РЪд M' РЪДрхЏ ╬│') Рєњ valStack TРЌЙ (pm M' N) ╬│'
        Рєњ valStack TРЌЙ M ╬│

    _№╣љ_РѕиlРЪе_РЪЕ_ : (LHS : ╬Њ РібрхЏ A) Рєњ (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ {LHS' : ╬Њ' РібрхЏ A} Рєњ {╬│' : РЪд ╬Њ' РЪД╦Б} Рєњ (LРЅАL' : РЪд LHS РЪДрхЏ ╬│ РЅА РЪд LHS' РЪДрхЏ ╬│') Рєњ {RHS : ╬Њ' РібрхЏ B} Рєњ valStack TРЌЙ (pair LHS' RHS) ╬│'
        Рєњ valStack TРЌЙ LHS ╬│

    _№╣љ_РѕиrРЪе_РЪЕ_ : (RHS : ╬Њ РібрхЏ A) Рєњ (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ {RHS' : ╬Њ' РібрхЏ A} Рєњ {╬│' : РЪд ╬Њ' РЪД╦Б} Рєњ (RРЅАR' : РЪд RHS РЪДрхЏ ╬│ РЅА РЪд RHS' РЪДрхЏ ╬│') Рєњ {LHS : ╬Њ' РібрхЏ B} Рєњ valStack TРЌЙ (pair LHS RHS') ╬│'
        Рєњ valStack TРЌЙ RHS ╬│


data VState : (TРЌЙ : Ty) Рєњ Set where

     Рѕў_ : {M : ╬Њ РібрхЏ A} Рєњ {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ valStack TРЌЙ M ╬│ Рєњ VState TРЌЙ

     РѕЎ[var]_ : {i : ╬Њ РѕІ X} Рєњ {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ valStack TРЌЙ (var i) ╬│ Рєњ VState TРЌЙ

     РѕЎ[lam]_ : {M : (╬Њ РѕЎ X) РібрХю Y} Рєњ {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ valStack TРЌЙ (lam M) ╬│ Рєњ VState TРЌЙ

     РѕЎ[unit]_ : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ valStack TРЌЙ unit ╬│ Рєњ VState TРЌЙ

     РѕЎ[pair]_ : {x : ╬Њ РібрхЏ X} Рєњ {y : ╬Њ РібрхЏ Y} Рєњ {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ valStack TРЌЙ (pair x y) ╬│ Рєњ VState TРЌЙ

data _~>рхЏрхЏ_ : VState TРЌЙ Рєњ VState TРЌЙ Рєњ Set where

     ~Рѕўvar~>   : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ {i : ╬Њ РѕІ X} Рєњ {tail : valStack TРЌЙ (var i) ╬│} Рєњ Рѕў tail ~>рхЏрхЏ РѕЎ[var] tail

     ~Рѕўlam~> : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ {M : (╬Њ РѕЎ X) РібрХю Y} Рєњ {tail : valStack TРЌЙ (lam M) ╬│} Рєњ Рѕў tail ~>рхЏрхЏ РѕЎ[lam] tail

     ~Рѕўpair~> : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ {LHS : ╬Њ РібрхЏ X} Рєњ {RHS : ╬Њ РібрхЏ Y} Рєњ {tail : valStack TРЌЙ (pair LHS RHS) ╬│} Рєњ Рѕў tail ~>рхЏрхЏ Рѕў LHS №╣љ ╬│ РѕиlРЪе refl РЪЕ tail

     ~Рѕўpm~> : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ {M : ╬Њ РібрхЏ X `├Ќ Y} Рєњ {N : (╬Њ РѕЎ X РѕЎ Y) РібрхЏ Z} Рєњ {tail : valStack TРЌЙ (pm M N) ╬│} Рєњ Рѕў tail ~>рхЏрхЏ Рѕў M №╣љ ╬│ РѕиpmРЪе refl РЪЕ tail

     ~Рѕўunit~> : {╬│ : РЪд ╬Њ РЪД╦Б} Рєњ {tail : valStack TРЌЙ unit ╬│} Рєњ Рѕў tail ~>рхЏрхЏ РѕЎ[unit] tail

     -- (РѕЎ var Рѕи pm Рѕи tail) transitions

     ~РѕЎvarРѕиpmРќа~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б)
                 Рєњ (i : ╬Њ РѕІ X `├Ќ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z')
                 Рєњ (РЅАM : РЪд var i РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│')
                 Рєњ    РѕЎ[var] var i №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' Рќа
                      ~>рхЏрхЏ
                        Рѕў N №╣љ ((╬│' , projРѓЂ (РЪд var i РЪДрхЏ ╬│)) , projРѓѓ (РЪд var i РЪДрхЏ ╬│)) Рќа

     ~РѕЎvarРѕиpmРѕиpm~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (i : ╬Њ РѕІ X `├Ќ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ X' `├Ќ Y')
                 Рєњ {M' : ╬Њ'' РібрхЏ X' `├Ќ Y'} Рєњ {N' : (╬Њ'' РѕЎ X' РѕЎ Y') РібрхЏ Z}
                 Рєњ (РЅАM : РЪд var i РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАM' : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд M' РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pm M' N') ╬│'')
                 Рєњ   РѕЎ[var] var i №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиpmРЪе РЅАM' РЪЕ tail
                      ~>рхЏрхЏ
                      Рѕў N №╣љ ((╬│' ,  projРѓЂ (РЪд var i РЪДрхЏ ╬│)) ,  projРѓѓ (РЪд var i РЪДрхЏ ╬│)) РѕиpmРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАM' РЪЕ tail

     ~РѕЎvarРѕиpmРѕиl~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (i : ╬Њ РѕІ X `├Ќ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z)
                 Рєњ {LHS : ╬Њ'' РібрхЏ Z} Рєњ {RHS : ╬Њ'' РібрхЏ Z'}
                 Рєњ (РЅАM : РЪд var i РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАLHS : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд LHS РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pair LHS RHS) ╬│'')
                 Рєњ    РѕЎ[var] var i №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиlРЪе РЅАLHS РЪЕ tail
                      ~>рхЏрхЏ
                       Рѕў N №╣љ ((╬│' ,  projРѓЂ (РЪд var i РЪДрхЏ ╬│)) ,  projРѓѓ (РЪд var i РЪДрхЏ ╬│)) РѕиlРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАLHS РЪЕ tail

     ~РѕЎvarРѕиpmРѕиr~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (i : ╬Њ РѕІ X `├Ќ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z')
                 Рєњ {LHS : ╬Њ'' РібрхЏ Z} Рєњ {RHS : ╬Њ'' РібрхЏ Z'}
                 Рєњ (РЅАM : РЪд var i РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАRHS : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд RHS РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pair LHS RHS) ╬│'')
                 Рєњ    РѕЎ[var] var i №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиrРЪе РЅАRHS РЪЕ tail
                      ~>рхЏрхЏ
                       Рѕў N №╣љ ((╬│' , projРѓЂ (РЪд var i РЪДрхЏ ╬│)) , projРѓѓ (РЪд var i РЪДрхЏ ╬│)) РѕиrРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАRHS РЪЕ tail

     -- (РѕЎ pair Рѕи pm Рѕи tail) transitions
     ~РѕЎpairРѕиpmРќа~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б)
                 Рєњ (x : ╬Њ РібрхЏ X) Рєњ (y : ╬Њ РібрхЏ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z')
                 Рєњ (РЅАM : РЪд pair x y РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│')
                 Рєњ    РѕЎ[pair] pair x y №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' Рќа
                      ~>рхЏрхЏ
                       Рѕў N №╣љ ((╬│' ,  РЪд x РЪДрхЏ ╬│) ,  РЪд y РЪДрхЏ ╬│) Рќа

     ~РѕЎpairРѕиpmРѕиpm~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (x : ╬Њ РібрхЏ X) Рєњ (y : ╬Њ РібрхЏ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ X' `├Ќ Y')
                 Рєњ {M' : ╬Њ'' РібрхЏ X' `├Ќ Y'} Рєњ {N' : (╬Њ'' РѕЎ X' РѕЎ Y') РібрхЏ C}
                 Рєњ (РЅАM : РЪд pair x y РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАM' : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд M' РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pm M' N') ╬│'')
                 Рєњ   РѕЎ[pair] pair x y №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиpmРЪе РЅАM' РЪЕ tail
                      ~>рхЏрхЏ
                      Рѕў N №╣љ ((╬│' ,  РЪд x РЪДрхЏ ╬│) ,  РЪд y РЪДрхЏ ╬│) РѕиpmРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАM' РЪЕ tail

     ~РѕЎpairРѕиpmРѕиl~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (x : ╬Њ РібрхЏ X) Рєњ (y : ╬Њ РібрхЏ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z)
                 Рєњ {LHS : ╬Њ'' РібрхЏ Z} Рєњ {RHS : ╬Њ'' РібрхЏ Z'}
                 Рєњ (РЅАM : РЪд pair x y РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАLHS : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд LHS РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pair LHS RHS) ╬│'')
                 Рєњ    РѕЎ[pair] pair x y №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиlРЪе РЅАLHS РЪЕ tail
                      ~>рхЏрхЏ
                       Рѕў N №╣љ ((╬│' ,  РЪд x РЪДрхЏ ╬│) ,  РЪд y РЪДрхЏ ╬│) РѕиlРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАLHS РЪЕ tail

     ~РѕЎpairРѕиpmРѕиr~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (x : ╬Њ РібрхЏ X) Рєњ (y : ╬Њ РібрхЏ Y)
                 Рєњ (M : ╬Њ' РібрхЏ X `├Ќ Y) Рєњ (N : (╬Њ' РѕЎ X РѕЎ Y) РібрхЏ Z')
                 Рєњ {LHS : ╬Њ'' РібрхЏ Z} Рєњ {RHS : ╬Њ'' РібрхЏ Z'}
                 Рєњ (РЅАM : РЪд pair x y РЪДрхЏ ╬│ РЅА РЪд M РЪДрхЏ ╬│') Рєњ (РЅАRHS : РЪд (pm M N) РЪДрхЏ ╬│' РЅА РЪд RHS РЪДрхЏ ╬│'')
                 Рєњ (tail : valStack TРЌЙ (pair LHS RHS) ╬│'')
                 Рєњ    РѕЎ[pair] pair x y №╣љ ╬│ РѕиpmРЪе РЅАM РЪЕ pm M N №╣љ ╬│' РѕиrРЪе РЅАRHS РЪЕ tail
                      ~>рхЏрхЏ
                       Рѕў N №╣љ ((╬│' ,  РЪд x РЪДрхЏ ╬│) ,  РЪд y РЪДрхЏ ╬│) РѕиrРЪе trans (cong (╬╗ p Рєњ (assocl №╝Џ РЪд N РЪДрхЏ) (╬│' , p) ) РЅАM) РЅАRHS РЪЕ tail

     -------------------------------------------------------------------------------------

     -- (РѕЎ T Рѕи (_ №╣љ RHS) Рѕи tail) transitions with T = var i
     ~РѕЎvarРѕиlРќа~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б)
                 Рєњ (i : ╬Њ РѕІ X)
                 Рєњ (LHS : ╬Њ' РібрхЏ X) Рєњ (RHS : ╬Њ' РібрхЏ Y)
                 Рєњ (РЅАLHS : РЪд var i РЪДрхЏ ╬│ РЅА РЪд LHS РЪДрхЏ ╬│')
                 Рєњ   РѕЎ[var] var i №╣љ ╬│ РѕиlРЪе РЅАLHS РЪЕ pair LHS RHS №╣љ ╬│' Рќа
                      ~>рхЏрхЏ
                     Рѕў RHS №╣љ ╬│' РѕиrРЪе refl РЪЕ pair (var h) (wk-val (wk-wk wk-id) RHS) №╣љ (╬│' ,  РЪд var i РЪДрхЏ ╬│) Рќа

     ~РѕЎvarРѕиlРѕиpm~> : (╬│ : РЪд ╬Њ РЪД╦Б) Рєњ (╬│' : РЪд ╬Њ' РЪД╦Б) Рєњ {╬│'' : РЪд ╬Њ'' РЪД╦Б}
                 Рєњ (i : ╬Њ РѕІ X)
                 Рєњ (LHS : ╬Њ' РібрхЏ X) Рєњ (RHS : ╬Њ' РібрхЏ Y)
                 Рєњ {M' : ╬Њ'' РібрхЏ X `├Ќ Y} Рєњ {N' : (╬Њ'' РѕЎ X РѕЎ Y) РібрхЏ Z}
