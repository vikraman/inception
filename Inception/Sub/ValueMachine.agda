data valStack : (Tв—ҫ : Ty) вҶ’ (О“ вҠўбөӣ A) вҶ’ вҹҰ О“ вҹ§ЛЈ вҶ’ Set where

    _п№җ_в–  : (M : О“ вҠўбөӣ Tв—ҫ) вҶ’ (Оі : вҹҰ О“ вҹ§ЛЈ) вҶ’ valStack Tв—ҫ M Оі

    _п№җ_вҲ·pmвҹЁ_вҹ©_ : (M : О“ вҠўбөӣ A `Г— B) вҶ’ (Оі : вҹҰ О“ вҹ§ЛЈ) вҶ’ {M' : О“' вҠўбөӣ A `Г— B} вҶ’ {Оі' : вҹҰ О“' вҹ§ЛЈ} вҶ’ {N : (О“' вҲҷ A вҲҷ B) вҠўбөӣ C} вҶ’ .(MвүЎM' : вҹҰ M вҹ§бөӣ Оі вүЎ вҹҰ M' вҹ§бөӣ Оі') вҶ’ valStack Tв—ҫ (pm M' N) Оі'
        вҶ’ valStack Tв—ҫ M Оі

    _п№җ_вҲ·lвҹЁ_вҹ©_ : (LHS : О“ вҠўбөӣ A) вҶ’ (Оі : вҹҰ О“ вҹ§ЛЈ) вҶ’ {LHS' : О“' вҠўбөӣ A} вҶ’ {Оі' : вҹҰ О“' вҹ§ЛЈ} вҶ’ .(LвүЎL' : вҹҰ LHS вҹ§бөӣ Оі вүЎ вҹҰ LHS' вҹ§бөӣ Оі') вҶ’ {RHS : О“' вҠўбөӣ B} вҶ’ valStack Tв—ҫ (pair LHS' RHS) Оі'
        вҶ’ valStack Tв—ҫ LHS Оі

    _п№җ_вҲ·rвҹЁ_вҹ©_ : (RHS : О“ вҠўбөӣ A) вҶ’ (Оі : вҹҰ О“ вҹ§ЛЈ) вҶ’ {RHS' : О“' вҠўбөӣ A} вҶ’ {Оі' : вҹҰ О“' вҹ§ЛЈ} вҶ’ .(RвүЎR' : вҹҰ RHS вҹ§бөӣ Оі вүЎ вҹҰ RHS' вҹ§бөӣ Оі') вҶ’ {LHS : О“' вҠўбөӣ B} вҶ’ valStack Tв—ҫ (pair LHS RHS') Оі'
        вҶ’ valStack Tв—ҫ RHS Оі


data VState : (Tв—ҫ : Ty) вҶ’ Set where

     вҲҳ_ : {M : О“ вҠўбөӣ A} вҶ’ {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ valStack Tв—ҫ M Оі вҶ’ VState Tв—ҫ

     вҲҷ[var]_ : {i : О“ вҲӢ X} вҶ’ {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ valStack Tв—ҫ (var i) Оі вҶ’ VState Tв—ҫ

     вҲҷ[lam]_ : {M : (О“ вҲҷ X) вҠўб¶ң Y} вҶ’ {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ valStack Tв—ҫ (lam M) Оі вҶ’ VState Tв—ҫ

     вҲҷ[unit]_ : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ valStack Tв—ҫ unit Оі вҶ’ VState Tв—ҫ

     вҲҷ[pair]_ : {x : О“ вҠўбөӣ X} вҶ’ {y : О“ вҠўбөӣ Y} вҶ’ {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ valStack Tв—ҫ (pair x y) Оі вҶ’ VState Tв—ҫ

data _~>бөӣбөӣ_ : VState Tв—ҫ вҶ’ VState Tв—ҫ вҶ’ Set where

     ~вҲҳvar~>   : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ {i : О“ вҲӢ X} вҶ’ {tail : valStack Tв—ҫ (var i) Оі} вҶ’ вҲҳ tail ~>бөӣбөӣ вҲҷ[var] tail

     ~вҲҳlam~> : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ {M : (О“ вҲҷ X) вҠўб¶ң Y} вҶ’ {tail : valStack Tв—ҫ (lam M) Оі} вҶ’ вҲҳ tail ~>бөӣбөӣ вҲҷ[lam] tail

     ~вҲҳpair~> : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ {LHS : О“ вҠўбөӣ X} вҶ’ {RHS : О“ вҠўбөӣ Y} вҶ’ {tail : valStack Tв—ҫ (pair LHS RHS) Оі} вҶ’ вҲҳ tail ~>бөӣбөӣ вҲҳ LHS п№җ Оі вҲ·lвҹЁ refl вҹ© tail

     ~вҲҳpm~> : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ {M : О“ вҠўбөӣ X `Г— Y} вҶ’ {N : (О“ вҲҷ X вҲҷ Y) вҠўбөӣ Z} вҶ’ {tail : valStack Tв—ҫ (pm M N) Оі} вҶ’ вҲҳ tail ~>бөӣбөӣ вҲҳ M п№җ Оі вҲ·pmвҹЁ refl вҹ© tail

     ~вҲҳunit~> : {Оі : вҹҰ О“ вҹ§ЛЈ} вҶ’ {tail : valStack Tв—ҫ unit Оі} вҶ’ вҲҳ tail ~>бөӣбөӣ вҲҷ[unit] tail

